# .gitignore for Go + Node.js + Docker project

# Environment & Secrets
.env
.env.local
.env.*.local
*.env
!.env.example

# Frontend / Node.js
node_modules/
dist/
dist-ssr/
*.local
build/
.next/
out/
.cache/
.vite/
.npm-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Go / Backend
# Binaries and compiled object files
bin/
main
main.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test and coverage
*.test
*.out
coverage.txt
vendor/

# Docker
docker-compose.override.yml
.docker/
data/
db_data/
redis_data/
logs/
*.log

# IDEs & Editors
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*~
.DS_Store

# Misc
tmp/
temp/
obj/
