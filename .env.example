# Safe template only.
# For local development, copy this file to `.env.local` and fill in real values there.
# `.env.local` is intentionally gitignored and preferred by the Makefile/Compose workflow.

POSTGRES_DB=ecommerce
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-db-password

JWT_SECRET=change-me-jwt-secret-at-least-32-chars
REDIS_PASSWORD=
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me-rabbitmq-password
FRONTEND_BASE_URL=http://localhost:3000
PAYMENT_GATEWAY_MOMO_RETURN_URL=http://localhost:3000/payments

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=ND Shop
SMTP_FROM_ADDRESS=

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_OTP_MESSAGE_TTL_SECONDS=300
TELEGRAM_OTP_RESEND_COOLDOWN_SECONDS=60
TELEGRAM_OTP_MAX_ATTEMPTS=5
TELEGRAM_OTP_DAILY_LIMIT_PER_USER=5
TELEGRAM_OTP_HOURLY_LIMIT_PER_IP=10
TELEGRAM_SECRET_PEPPER=change-me

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
